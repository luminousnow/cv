  "license": "ISC",
  "bugs": {
    "url": "https://github.com/luminousnow/cv/issues"
  },
  "homepage": "https://luminousnow.github.io/cv",
  "devDependencies": {
    "gh-pages": "^3.2.3",
    "parcel-bundler": "^1.12.5",
    "parcel-plugin-nuke-dist": "^1.0.1",
    "posthtml": "^0.15.2",
    "posthtml-include": "^1.7.1",
    "prettier": "^2.3.0",
    "sass": "^1.34.0"
  },
  "dependencies": {
    "bootstrap": "^5.1.2",
    "modern-normalize": "^1.1.0",
    "scss": "^0.2.4"
  }
}
