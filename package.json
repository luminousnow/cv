{
  "name": "cv",
  "version": "1.0.0",
  "description": "npm run dev - running live server for dev npm run dev npm run deploy - build and\r deploy on github. See branch \"gh-page\"",
  "main": "./src/index.js",
  "scripts": {
    "dev": "parcel src/*.html",
    "build": "parcel build src/*.html --public-url /cv/",
    "predeploy": "npm run build",
    "deploy": "gh-pages -d dist"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luminousnow/cv.git"
  },
